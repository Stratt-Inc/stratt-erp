# STRATT Backend — Variables d'environnement
# Copier : cp .env.example .env  (pour go run ./cmd/api en local)

PORT=8080
APP_ENV=development

# Base de données (docker compose -f docker-compose.dev.yml up postgres)
DATABASE_URL=postgresql://stratt:stratt_dev_password@localhost:5432/stratt_dev?sslmode=disable

# JWT
JWT_SECRET=dev_jwt_secret_min_32_chars_xxxxxxxx
JWT_ACCESS_EXP_MINUTES=60
JWT_REFRESH_EXP_DAYS=30

# Redis (docker compose -f docker-compose.dev.yml up redis)
REDIS_URL=redis://localhost:6379

# Meilisearch (docker compose -f docker-compose.dev.yml up meilisearch)
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=stratt_meili_dev_key

# MinIO (docker compose -f docker-compose.dev.yml up minio)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=stratt_minio
S3_SECRET_KEY=stratt_minio_secret
S3_BUCKET=stratt

FRONTEND_URL=http://localhost:3000

# Optionnel
# ANTHROPIC_API_KEY=sk-ant-...
# INSEE_TOKEN=...
