# STRATT — Variables d'environnement développement local
# Copier ce fichier : cp .env.dev.example .env.dev
# Utilisé par docker-compose.dev.yml

# ── Base de données ──────────────────────────────────────
POSTGRES_DB=stratt_dev
POSTGRES_USER=stratt
POSTGRES_PASSWORD=stratt_dev_password
DATABASE_URL=postgresql://stratt:stratt_dev_password@localhost:5432/stratt_dev?sslmode=disable

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=dev_jwt_secret_min_32_chars_xxxxxxxx
JWT_ACCESS_EXP_MINUTES=60
JWT_REFRESH_EXP_DAYS=30

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Meilisearch ──────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=stratt_meili_dev_key

# ── MinIO / S3 ───────────────────────────────────────────
MINIO_ROOT_USER=stratt_minio
MINIO_ROOT_PASSWORD=stratt_minio_secret
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=stratt_minio
S3_SECRET_KEY=stratt_minio_secret
S3_BUCKET=stratt

# ── Frontend ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── APIs externes (optionnel pour le dev) ────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# INSEE_TOKEN=...
