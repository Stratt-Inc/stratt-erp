# ═══════════════════════════════════════════════════════
# Axiora ERP SaaS — Variables d'environnement
# Copier en .env et remplir les valeurs sensibles
# ═══════════════════════════════════════════════════════

# ── Environnement ───────────────────────────────────────
APP_ENV=development
APP_NAME=Axiora

# ── API Go ──────────────────────────────────────────────
API_PORT=8080

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_min_32_chars_xxxxxxxxxxxx
JWT_ACCESS_EXP_MINUTES=15
JWT_REFRESH_EXP_DAYS=30

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_DB=axiora_dev
POSTGRES_USER=axiora
POSTGRES_PASSWORD=axiora_dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://axiora:axiora_dev_password@localhost:5432/axiora_dev?sslmode=disable

# ── Redis ───────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── MinIO (stockage S3 local) ───────────────────────────
MINIO_ROOT_USER=axiora_minio
MINIO_ROOT_PASSWORD=axiora_minio_secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=axiora

# ── Meilisearch ─────────────────────────────────────────
MEILISEARCH_PORT=7700
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=axiora_meili_dev_key

# ── Frontend Next.js ────────────────────────────────────
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── SMTP (optionnel — emails transactionnels) ────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@axiora.io
