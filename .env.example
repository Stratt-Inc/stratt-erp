# ═══════════════════════════════════════════════════════
# Axiora — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ═══════════════════════════════════════════════════════

# ── Anthropic / IA ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Stack Auth (https://stack-auth.com) ─────────────────
STACK_AUTH_SECRET_KEY=
STACK_AUTH_PUBLISHABLE_KEY=
NEXT_PUBLIC_STACK_AUTH_PROJECT_ID=

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_DB=axiora_dev
POSTGRES_USER=axiora
POSTGRES_PASSWORD=axiora_dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://axiora:axiora_dev_password@localhost:5432/axiora_dev

# ── Redis ───────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── MinIO (stockage S3 local) ───────────────────────────
MINIO_ROOT_USER=axiora_minio
MINIO_ROOT_PASSWORD=axiora_minio_secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=axiora_minio
S3_SECRET_KEY=axiora_minio_secret
S3_BUCKET=axiora-exports

# ── API Go ──────────────────────────────────────────────
API_PORT=8080
JWT_SECRET=change_me_in_production_min_32_chars

# ── Frontend Next.js ────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Environnement ───────────────────────────────────────
APP_ENV=development
NODE_ENV=development
